{
  "name": "stylus-true",
  "version": "1.0.3",
  "description": "Framework to unit test your Stylus files.",
  "main": "styl/_true.styl",
  "engines": {
    "node": ">=22.22.2"
  },
  "directories": {
    "lib": "lib",
    "test": "test"
  },
  "dependencies": {
    "@vitest/utils": "^4.1.9",
    "chalk": "^5.6.2",
    "postcss": "^8.5.16",
    "stylus": "0.64.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.1.0",
    "@commitlint/config-conventional": "^21.1.0",
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.20.0",
    "@typescript-eslint/eslint-plugin": "^8.62.0",
    "@typescript-eslint/parser": "^8.62.0",
    "@vitest/coverage-v8": "^4.1.9",
    "commit-and-tag-version": "^12.7.3",
    "cz-conventional-changelog": "^3.3.0",
    "eslint": "^10.6.0",
    "glob": "^13.0.6",
    "husky": "^9.1.7",
    "kss": "^3.1.0",
    "lint-staged": "^17.0.8",
    "niepsuj-kss-template": "^1.3.0",
    "postcss-styl": "^0.12.3",
    "prettier": "^3.9.3",
    "remark": "^15.0.1",
    "remark-parse": "^11.0.0",
    "remark-stringify": "^11.0.0",
    "rimraf": "^6.1.3",
    "stylelint": "^17.14.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "scripts": {
    "build": "rimraf lib && tsc -p tsconfig.json",
    "lint:ts": "eslint \"src/**/*.ts\"",
    "lint:js": "eslint \"lib/**/*.js\" \"test/**/*.js\"",
    "lint:styl": "stylelint \"styl/**/*.styl\" \"test/styl/**/*.styl\"",
    "lint:lib": "eslint \"lib/**/*.js\"",
    "lint": "npm run lint:ts && npm run lint:js && npm run lint:styl",
    "check": "npm run build && npm run lint && npm run test:bun:run && npm run test:vitest:run",
    "test": "npm run build && npm run test:bun:run && npm run test:vitest:run",
    "test:bun:run": "bun test test/lib.spec.js test/stylus.spec.js",
    "test:vitest:run": "vitest run",
    "test:bun": "npm run build && npm run test:bun:run",
    "test:vitest": "npm run build && npm run test:vitest:run",
    "coverage": "npm run build && vitest run --coverage",
    "kss": "npx kss --config kss-config.json",
    "compile": "npm run build",
    "prepack": "npm run build",
    "prepublishOnly": "npm run check",
    "commit": "npm run test && npm run kss && git add . && git cz",
    "release:initial": "git fetch --tags --force && $ bunx -- commit-and-tag-version --release-as v1.0.0",
    "release": "git fetch --tags --force && commit-and-tag-version",
    "push": "git push --follow-tags",
    "prepare": "husky"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ghaschel/stylus-true.git"
  },
  "keywords": [
    "stylus",
    "unit",
    "test",
    "unit-test",
    "unit",
    "test",
    "css",
    "vitest",
    "bun",
    "framework"
  ],
  "author": "Guilherme Haschel",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/ghaschel/stylus-true/issues"
  },
  "homepage": "https://github.com/ghaschel/stylus-true#readme",
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  }
}
