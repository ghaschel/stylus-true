{
  "name": "stylus-true",
  "version": "1.0.3",
  "description": "Framework to unit test your Stylus files.",
  "main": "styl/_true.styl",
  "engines": {
    "node": ">=16"
  },
  "directories": {
    "lib": "lib",
    "test": "test"
  },
  "dependencies": {
    "chalk": "^4.0.0",
    "glob": "^7.1.4",
    "jest-diff": "^29.7.0",
    "lodash.find": "^4.6.0",
    "lodash.foreach": "^4.5.0",
    "lodash.last": "^3.0.0",
    "mocha": "^7.0.1",
    "niepsuj-kss-template": "^1.1.6",
    "nyc": "^15.0.0",
    "postcss": "^8.5.15",
    "stylus": "0.64.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^8.1.0",
    "@commitlint/config-conventional": "^8.1.0",
    "@semantic-release/changelog": "^5.0.0",
    "@semantic-release/git": "^9.0.0",
    "@types/node": "^16.18.126",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "chai": "^4.2.0",
    "codecov": "^3.5.0",
    "cz-conventional-changelog": "^3.0.2",
    "eslint": "^8.57.1",
    "husky": "^4.0.2",
    "jest": "^29.7.0",
    "kss": "^3.0.0-beta.25",
    "lint-staged": "^13.3.0",
    "prettier": "^2.0.0",
    "pretty-quick": "^2.0.0",
    "requirejs": "^2.3.6",
    "rimraf": "^5.0.10",
    "semantic-release": "^16.0.0",
    "standard-version": "^8.0.0",
    "stylint": "^2.0.0",
    "typescript": "^5.9.3"
  },
  "scripts": {
    "build": "rimraf lib && tsc -p tsconfig.json",
    "lint:ts": "eslint \"src/**/*.ts\"",
    "lint:js": "eslint \"lib/**/*.js\" \"test/**/*.js\"",
    "lint:lib": "eslint \"lib/**/*.js\"",
    "lint": "npm run lint:ts && npm run lint:js",
    "check": "npm run build && npm run lint && npm run test:mocha:run && npm run test:jest:run",
    "test": "npm run build && npm run test:mocha:run && npm run test:jest:run",
    "nyc": "nyc --reporter=html --reporter=text mocha",
    "report-coverage": "nyc report --reporter=text-lcov > coverage.lcov && codecov",
    "test:mocha:run": "mocha \"test/*.spec.js\"",
    "test:jest:run": "jest test/lib.spec.js test/stylus.spec.js",
    "test:mocha": "npm run build && npm run test:mocha:run",
    "test:jest": "npm run build && npm run test:jest:run",
    "coverage": "nyc report --reporter=text-lcov > coverage.lcov && codecov",
    "debug": "mocha debug",
    "kss": "npx kss --config kss-config.json",
    "compile": "npm run build",
    "prepack": "npm run build",
    "prepublishOnly": "npm run check",
    "commit": "npm run test && npm run kss && git add . && git cz",
    "semantic-release": "semantic-release"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ghaschel/stylus-true.git"
  },
  "keywords": [
    "stylus",
    "unit",
    "test",
    "unit-test",
    "unit",
    "test",
    "css",
    "jest",
    "mocha",
    "framework"
  ],
  "author": "Guilherme Haschel",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/ghaschel/stylus-true/issues"
  },
  "homepage": "https://github.com/ghaschel/stylus-true#readme",
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged && npm run build && npm run lint:lib && git add lib",
      "commit-msg": "commitlint -E HUSKY_GIT_PARAMS"
    }
  },
  "lint-staged": {
    "src/**/*.ts": [
      "eslint --fix",
      "prettier --write"
    ],
    "test/**/*.js": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  },
  "release": {
    "plugins": [
      "@semantic-release/commit-analyzer",
      "@semantic-release/release-notes-generator",
      [
        "@semantic-release/npm",
        {
          "npmPublish": false
        }
      ],
      "@semantic-release/github"
    ],
    "prepare": [
      "@semantic-release/changelog",
      "@semantic-release/npm",
      {
        "path": "@semantic-release/git",
        "assets": [
          "package.json",
          "package-lock.json",
          "CHANGELOG.md"
        ],
        "message": "chore(release): ${nextRelease.version} [skip ci]nn${nextRelease.notes}"
      }
    ]
  }
}
