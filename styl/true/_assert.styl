// assert($description = null)
//
// **[public:{output}]** Define a CSS-output assertion. Use it as a wrapper around one `output()` block and one `expect()`, `contains()`, or `contains-string()` check. JavaScript runner output assertions are parsed with PostCSS.
//
// Weight: -10
//
// <b>Parameters:</b>
// <ul>
// <li>$description = null - <b>{string}</b> <b><i>Optional output assertion description. When omitted, the JavaScript parser uses the current test name for runner output.</i></b></li>
// <li>{block} - <b><i>Use `output()` and `expect()` mixins to define blocks for comparison</i></b></li>
// </ul>
//
// ~
//
// **Usage:**
// ```stylus
// +test('Stylus math compiles before output') {
//   +assert('You can also describe the assertion...') {
//     +output() {
//       width: 14em + 2;
//     }
//     +expect() {
//       width: 16em;
//     }
//   }
// }
// ```
//
// Styleguide Mixins.assert
assert($description = null) {
  $tmp = $description ? unquote($description) : '';

  _true-output-context('assert');
  _true-context-mixin('assert', $tmp ? '[output] %s' % $tmp : '[output]');
  _true-message(' ASSERT: %s ' % $tmp, 'comments');

  {block};

  _true-output-context(null);
  _true-update-test('output-to-css');
  _true-update-stats-count('assertions');
  // _true-context-pop();
  _true-message(' END_ASSERT ', 'comments');
}

