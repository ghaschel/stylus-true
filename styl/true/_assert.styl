// Styleguide Mixins.assert-unequal
assert-unequal($assert, $expected, $description = null, $inspect = false) {
  if ($inspect) {
    $assert = s('%s' % $assert);
    $expected = s('%s' % $expected);
  }

  $tmp = $description ? '[assert-unequal] %s' % unquote($description) : '[assert-unequal]';

  _true-context-mixin('assert', $tmp);
  _true-assert-results($assert, $expected, 'unequal');
}

// not-equal($assert, $expected, $description, $inspect)
//
// **[public:{output}]** Alias for `assert-unequal()`, matching Sass True. The optional `$inspect` argument is Stylus-specific.
//
// Weight: -10
//
