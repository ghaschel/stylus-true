use('../../lib/true-json-equal.js');

// _true-assert-label($name, $description)
//
// **[private:{string}]** Build the output label for assertion comments.
//
// Weight: 0
//
// $name - **{string}** ***Assertion name***
// $description = null - **{string|null}** ***Optional assertion description***
//
// Styleguide Functions._true-assert-label
_true-assert-label($name, $description = null) {
  return $description ? '[%s] %s' % (unquote($name) unquote($description)) : '[%s]' % unquote($name);
}

// _true-string-value($value)
//
// **[private:{string}]** Coerce identifiers or strings into a Stylus string value.
//
// Weight: 0
//
// $value - **{any}** ***Value to stringify***
//
// Styleguide Functions._true-string-value
_true-string-value($value) {
  return '' + $value;
}

// _true-json-options($options)
//
// **[private:{object}]** Build options for Stylus `json()` assertions without mutating caller options.
//
// Weight: 0
//
// $options = null - **{object|null}** ***Optional `json()` options***
//
// Styleguide Functions._true-json-options
_true-json-options($options = null) {
  $json-options = {
    hash: true,
    'leave-strings': true
  };

  if ($options != null && type($options) == 'object') {
    for $key in (keys($options)) {
      $json-options[$key] = $options[$key];
    }
  }

  $json-options.hash = true;

  return $json-options;
}

// assert-true($assert, $description)
//
// **[public:{output}]** Assert that a value is truthy. Empty lists and empty strings are treated as false for this assertion.
//
// Weight: -10
//
// <b>Parameters:</b>
// <ul>
// <li>$assert - <b>{any}</b> <b><i>Asserted value to test</i></b></li>
// <li>$description = null - <b>{string}</b> <b><i>Optional description emitted in assertion comments. Omitted descriptions output the assertion type only.</i></b></li>
// </ul>
//
// ~
//
// **Usage:**
// ```stylus
// +test('Non-empty strings are truthy') {
//   assert-true(
//     'Hello World',
//     'You can optionally describe the assertion...'
//   );
// }
// ```
//
// Styleguide Mixins.assert-true
assert-true($assert, $description = null) {
  $truthy = _true-is-truthy($assert);
  $tmp = $description ? '[assert-true] %s' % unquote($description) : '[assert-true]';

  _true-context-mixin('assert', $tmp);
  _true-assert-results($truthy, true);
}

// is-truthy($assert, $description)
//
// **[public:{output}]** Alias for `assert-true()`, matching Sass True.
//
// Weight: -10
//
// Styleguide Mixins.is-truthy
is-truthy($assert, $description = null) {
  assert-true($assert, $description);
}

// assert-false($assert, $description)
//
// **[public:{output}]** Assert that a value is falsy. Empty lists and empty strings are treated as false for this assertion.
//
// Weight: -10
//
// <b>Parameters:</b>
// <ul>
// <li>$assert - <b>{any}</b> <b><i>Asserted value to test</i></b></li>
// <li>$description = null - <b>{string}</b> <b><i>Optional description emitted in assertion comments. Omitted descriptions output the assertion type only.</i></b></li>
// </ul>
//
// ~
//
// **Usage:**
// ```stylus
// +test('Empty strings are falsey') {
//   assert-false(
//     ''
//   );
// }
// ```
//
// Styleguide Mixins.assert-false
assert-false($assert, $description = null) {
  $falsey = !_true-is-truthy($assert);
  $tmp = $description ? '[assert-false] %s' % unquote($description) : '[assert-false]';

  _true-context-mixin('assert', $tmp);
  _true-assert-results($falsey, true);
}

// is-falsy($assert, $description)
//
// **[public:{output}]** Alias for `assert-false()`, matching Sass True.
//
// Weight: -10
//
// Styleguide Mixins.is-falsy
is-falsy($assert, $description = null) {
  assert-false($assert, $description);
}


// assert-equal($assert, $expected, $description, $inspect)
//
// **[public:{output}]** Assert that two Stylus values are equal.
//
// Weight: -10
//
// <b>Parameters:</b>
// <ul>
// <li>$assert - <b>{any}</b> <b><i>Asserted value to test</i></b></li>
// <li>$expected - <b>{any}</b> <b><i>Expected mismatch</i></b></li>
// <li>$description = null - <b>{string}</b> <b><i>Optional description emitted in assertion comments. Omitted descriptions output the assertion type only.</i></b></li>
// <li>$inspect = false - <b>{boolean}</b> <b><i>Optionally compare inspected values (useful for comparing CSS output rather than Stylus values)</i></b></li>
// </ul>
//
// ~
//
// **Usage:**
// ```stylus
// +test('Division works as expected in Stylus') {
//   assert-equal(
//     8 / 2,
//     4,
//     'You can optionally describe the assertion...'
//   );
// }
// ```
//
// Styleguide Mixins.assert-equal
assert-equal($assert, $expected, $description = null, $inspect = false) {
  if ($inspect) {
    $assert = s('%s' % $assert);
    $expected = s('%s' % $expected);
  }

  $tmp = $description ? '[assert-equal] %s' % unquote($description) : '[assert-equal]';

  _true-context-mixin('assert', $tmp);
  _true-assert-results($assert, $expected);
}

// is-equal($assert, $expected, $description, $inspect)
//
// **[public:{output}]** Alias for `assert-equal()`, matching Sass True. The optional `$inspect` argument is Stylus-specific.
//
// Weight: -10
//
// Styleguide Mixins.is-equal
is-equal($assert, $expected, $description = null, $inspect = false) {
  assert-equal($assert, $expected, $description, $inspect);
}

