// assert-true($assert, $description)
//
// **[public:{output}]** Assert that a value is truthy. Empty lists and empty strings are treated as false for this assertion.
//
// Weight: -10
//
// <b>Parameters:</b>
// <ul>
// <li>$assert - <b>{any}</b> <b><i>Asserted value to test</i></b></li>
// <li>$description = null - <b>{string}</b> <b><i>Optional description emitted in assertion comments. Omitted descriptions output the assertion type only.</i></b></li>
// </ul>
//
// ~
//
// **Usage:**
// ```stylus
// +test('Non-empty strings are truthy') {
//   assert-true(
//     'Hello World',
//     'You can optionally describe the assertion...'
//   );
// }
// ```
//
// Styleguide Mixins.assert-true
assert-true($assert, $description = null) {
  $truthy = _true-is-truthy($assert);
  $tmp = $description ? '[assert-true] %s' % unquote($description) : '[assert-true]';

  _true-context-mixin('assert', $tmp);
  _true-assert-results($truthy, true);
}

// is-truthy($assert, $description)
//
// **[public:{output}]** Alias for `assert-true()`, matching Sass True.
//
// Weight: -10
//
// Styleguide Mixins.is-truthy
is-truthy($assert, $description = null) {
  assert-true($assert, $description);
}

// assert-false($assert, $description)
//
// **[public:{output}]** Assert that a value is falsy. Empty lists and empty strings are treated as false for this assertion.
//
// Weight: -10
//
// <b>Parameters:</b>
// <ul>
// <li>$assert - <b>{any}</b> <b><i>Asserted value to test</i></b></li>
// <li>$description = null - <b>{string}</b> <b><i>Optional description emitted in assertion comments. Omitted descriptions output the assertion type only.</i></b></li>
// </ul>
//
// ~
//
// **Usage:**
// ```stylus
// +test('Empty strings are falsey') {
//   assert-false(
//     ''
//   );
// }
// ```
//
// Styleguide Mixins.assert-false
assert-false($assert, $description = null) {
  $falsey = !_true-is-truthy($assert);
  $tmp = $description ? '[assert-false] %s' % unquote($description) : '[assert-false]';

  _true-context-mixin('assert', $tmp);
  _true-assert-results($falsey, true);
}

// is-falsy($assert, $description)
//
// **[public:{output}]** Alias for `assert-false()`, matching Sass True.
//
// Weight: -10
//
// Styleguide Mixins.is-falsy
is-falsy($assert, $description = null) {
  assert-false($assert, $description);
}


// assert-equal($assert, $expected, $description, $inspect)
//
// **[public:{output}]** Assert that two Stylus values are equal.
//
// Weight: -10
//
// <b>Parameters:</b>
// <ul>
// <li>$assert - <b>{any}</b> <b><i>Asserted value to test</i></b></li>
// <li>$expected - <b>{any}</b> <b><i>Expected mismatch</i></b></li>
// <li>$description = null - <b>{string}</b> <b><i>Optional description emitted in assertion comments. Omitted descriptions output the assertion type only.</i></b></li>
// <li>$inspect = false - <b>{boolean}</b> <b><i>Optionally compare inspected values (useful for comparing CSS output rather than Stylus values)</i></b></li>
// </ul>
//
// ~
//
// **Usage:**
// ```stylus
// +test('Division works as expected in Stylus') {
//   assert-equal(
//     8 / 2,
//     4,
//     'You can optionally describe the assertion...'
//   );
// }
// ```
//
// Styleguide Mixins.assert-equal
assert-equal($assert, $expected, $description = null, $inspect = false) {
  if ($inspect) {
    $assert = s('%s' % $assert);
    $expected = s('%s' % $expected);
  }

  $tmp = $description ? '[assert-equal] %s' % unquote($description) : '[assert-equal]';

  _true-context-mixin('assert', $tmp);
  _true-assert-results($assert, $expected);
}

// is-equal($assert, $expected, $description, $inspect)
//
// **[public:{output}]** Alias for `assert-equal()`, matching Sass True. The optional `$inspect` argument is Stylus-specific.
//
// Weight: -10
//
// Styleguide Mixins.is-equal
is-equal($assert, $expected, $description = null, $inspect = false) {
  assert-equal($assert, $expected, $description, $inspect);
}

// assert-unequal($assert, $expected, $description, $inspect)
//
// **[public:{output}]** Assert that two Stylus values are not equal.
//
// Weight: -10
//
// <b>Parameters:</b>
// <ul>
// <li>$assert - <b>{any}</b> <b><i>Asserted value to test</i></b></li>
// <li>$expected - <b>{any}</b> <b><i>Expected mismatch</i></b></li>
// <li>$description = null - <b>{string}</b> <b><i>Optional description emitted in assertion comments. Omitted descriptions output the assertion type only.</i></b></li>
// <li>$inspect = false - <b>{boolean}</b> <b><i>Optionally compare inspected values (useful for comparing CSS output rather than Stylus values)</i></b></li>
// </ul>
//
// ~
//
// **Usage:**
// ```stylus
// +test('Strings and numbers hare not the same') {
//   assert-unequal(
//     1em,
//     '1em'
//   );
// }
// ```
//
// Styleguide Mixins.assert-unequal
assert-unequal($assert, $expected, $description = null, $inspect = false) {
  if ($inspect) {
    $assert = s('%s' % $assert);
    $expected = s('%s' % $expected);
  }

  $tmp = $description ? '[assert-unequal] %s' % unquote($description) : '[assert-unequal]';

  _true-context-mixin('assert', $tmp);
  _true-assert-results($assert, $expected, 'unequal');
}

// not-equal($assert, $expected, $description, $inspect)
//
// **[public:{output}]** Alias for `assert-unequal()`, matching Sass True. The optional `$inspect` argument is Stylus-specific.
//
// Weight: -10
//
// Styleguide Mixins.not-equal
not-equal($assert, $expected, $description = null, $inspect = false) {
  assert-unequal($assert, $expected, $description, $inspect);
}

// assert($description = null)
//
// **[public:{output}]** Define a CSS-output assertion. Use it as a wrapper around one `output()` block and one `expect()`, `contains()`, or `contains-string()` check. JavaScript runner output assertions are parsed with PostCSS.
//
// Weight: -10
//
// <b>Parameters:</b>
// <ul>
// <li>$description = null - <b>{string}</b> <b><i>Optional output assertion description. When omitted, the JavaScript parser uses the current test name for runner output.</i></b></li>
// <li>{block} - <b><i>Use `output()` and `expect()` mixins to define blocks for comparison</i></b></li>
// </ul>
//
// ~
//
// **Usage:**
// ```stylus
// +test('Stylus math compiles before output') {
//   +assert('You can also describe the assertion...') {
//     +output() {
//       width: 14em + 2;
//     }
//     +expect() {
//       width: 16em;
//     }
//   }
// }
// ```
//
// Styleguide Mixins.assert
assert($description = null) {
  $tmp = $description ? unquote($description) : '';

  _true-output-context('assert');
  _true-context-mixin('assert', $tmp ? '[output] %s' % $tmp : '[output]');
  _true-message(' ASSERT: %s ' % $tmp, 'comments');

  {block};

  _true-output-context(null);
  _true-update-test('output-to-css');
  _true-update-stats-count('assertions');
  // _true-context-pop();
  _true-message(' END_ASSERT ', 'comments');
}

// output($selector)
//
// **[public:{output}]** Define the CSS produced by the code under test. Use inside `assert()` with sibling `expect()`, `contains()`, or `contains-string()` checks.
//
// Weight: -10
//
// <b>Parameters:</b>
// <ul>
// <li>$selector = true - <b>{boolean}</b> <b><i>Optionally wrap the contents in a `.test-output` selector block, so you can test property-value output directly.</i></b></li>
// <li>{block} - <b><i>Define the test content to be checked</i></b></li>
// </ul>
//
// ~
//
// **Usage:**
// ```stylus
// +test('Stylus math compiles before output') {
//   +assert() {
//     +output() {
//       width: 14em + 2;
//     }
//     +expect() {
//       width: 16em;
//     }
//   }
// }
// ```
//
// Styleguide Mixins.output
output($selector = true) {
  _true-output-context('output');
  _true-message(' OUTPUT ', 'comments');

  if ($selector) {
    .test-output {
      {block};
    }
  } else {
    {block};
  }

  _true-message(' END_OUTPUT ', 'comments');
}


// expect($selector)
//
// **[public:{output}]** Define the exact CSS expected from the sibling `output()` block. The JavaScript runner compares normalized serialized CSS, so selector and declaration order remain significant.
//
// Weight: -10
//
// <b>Parameters:</b>
// <ul>
// <li>$selector = true - <b>{boolean}</b> <b><i>Optionally wrap the contents in a `.test-output` selector block, so you can test property-value output directly.</i></b></li>
// <li>{block} - <b><i>Define the expected results of a sibling `output()` mixin</i></b></li>
// </ul>
//
// ~
//
// **Usage:**
// ```stylus
// +test('Stylus math compiles before output') {
//   +assert() {
//     +output() {
//       width: 14em + 2;
//     }
//     +expect() {
//       width: 16em;
//     }
//   }
// }
// ```
//
// Styleguide Mixins.expect
expect($selector = true) {
  _true-output-context('expect');
  _true-message(' EXPECTED ', 'comments');

  if ($selector) {
    .test-output {
      {block};
    }
  } else {
    {block};
  }

  _true-message(' END_EXPECTED ', 'comments');
}

// contains($selector)
//
// **[public:{output}]** Define CSS that must be present within the sibling `output()` block. The JavaScript runner uses structural PostCSS containment: expected rules, declarations, comments, and at-rules must exist, declaration order inside a matching rule does not matter, and selectors are compared as normalized strings rather than selector algebra.
//
// Weight: -10
//
// <b>Parameters:</b>
// <ul>
// <li>$selector = true - <b>{boolean}</b> <b><i>Optionally wrap the contents in a `.test-output` selector block, so you can test property-value output directly.</i></b></li>
// <li>{block} - <b><i>Include any content that are part of this test</i></b></li>
// </ul>
//
// ~
//
// **Usage:**
// ```stylus
// +test('Stylus math compiles before output') {
//   +assert() {
//     +output() {
//       height: 100%;
//       width: 14em + 2;
//     }
//     +contains() {
//       width: 16em;
//     }
//   }
// }
// ```
//
// Styleguide Mixins.contains
contains($selector = true) {
  _true-output-context('contains');
  _true-message(' CONTAINED ', 'comments');

  if ($selector) {
    .test-output {
      {block};
    }
  } else {
    {block};
  }

  _true-message(' END_CONTAINED ', 'comments');
}

// contains-string($string-to-find)
//
// **[public:{output}]** Define a case-sensitive substring that must be present in the sibling `output()` block.
//
// Weight: -10
//
// <b>Parameters:</b>
// <ul>
// <li>$string-to-find - <b>{string}</b> <b><i>The substring to search for within the compiled CSS output.</i></b></li>
// </ul>
//
// ~
//
// **Usage:**
// ```stylus
// +test('Contains output strings') {
//   +assert() {
//     +output() {
//       height: 10px;
//       width: 20px;
//     }
//     contains-string('height');
//     contains-string('20px');
//   }
// }
// ```
//
// Styleguide Mixins.contains-string
contains-string($string-to-find) {
  _true-output-context('contains-string');
  _true-message(' CONTAINS_STRING ', 'comments');
  _true-message(unquote('' + $string-to-find), 'comments');
  _true-message(' END_CONTAINS_STRING ', 'comments');
}

// $map = { asserts }
//
// **[private]** Variable to store asserts.
//
// Weight: -0
//
// $asserts = () - **{string[]}** ***List of asserts***
//
// Styleguide Variables.$map
$map = {
  asserts: ()
}

// _true-assert-results($assert, $expected, $unequal, $terminal)
//
// **[private:{output}]** Get an official result, record it in the database and output, provide details as necessary, and end the assertion.
//
// Weight: 0
//
// $assert - **{any}** ***Value to consider***
// $expected - **{any}** ***Expected match***
// $unequal = false - **{boolean}** ***Set to `true` if the comparison is expected to fail***
// $terminal = $true-terminal-output.value.value - **{boolean}** ***Whether in case of failing it should output to terminal***
//
// Styleguide Mixins.__true-assert-results
_true-assert-results($assert, $expected, $unequal = false, $terminal = $true-terminal-output.value) {
  $result = _true-get-result($assert, $expected, $unequal);

  if ($result == 'pass') {
    _true-pass-details();
  } else {
    _true-fail-details($assert, $expected, $terminal);
  }

  _true-update-test($result);
  _true-update-stats-count('assertions');
  // _true-context-pop();
}

// _true-is-truthy($assert)
//
// **[private:{boolean}]** Check that a value is truthy (empty lists and strings return false)
//
// Weight: 0
//
// $assert - **{any}** ***Value to consider***
//
// Styleguide Functions._true-is-truthy
_true-is-truthy($assert) {
  $not = !!$assert;
  $list = $assert != ();
  $string = $assert != '';
  $truthy = ($not && $list && $string) ? true : false;

  return $truthy;
}
