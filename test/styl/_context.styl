
// Settings Tests
// ==============

_test-context-read-fake() {
  $_true-context.buffer = ();
  _true-context-mixin('fake', 'this scope is not real');

  return _true-context('fake');
}

_test-context-pop-fake() {
  $_true-context.buffer = ();
  _true-context-mixin('fake', 'this scope is not real');
  _true-context-pop();

  return _true-context('fake');
}

// Adding and removing context
+test-module('true-context & true-context-pop [functions]') {
  +test('Adds scope and name to context') {
    assert-equal(
      _test-context-read-fake(),
      'this scope is not real',
      'Sets the value of scope "fake" to "this scope is not real"'
    );

    assert-equal(
      _test-context-pop-fake(),
      null,
      'Confirm that "fake" scope has been removed',
      true
    );
  }

  +test('Removes the last matching scope') {
    $_true-context.buffer = ();

    _true-context-mixin('module', 'outer');
    _true-context-mixin('test', 'kept');
    _true-context-mixin('module', 'inner');
    _true-context-pop('module');

    assert-equal(_true-context('module'), 'outer');
    assert-equal(_true-context('test'), 'kept');

    $_true-context.buffer = ();
  }

  +test('Skips null context entries') {
    $_true-context.buffer = 'module|outer' null 'module|inner';

    assert-equal(_true-context('module'), 'inner');
    assert-equal(_true-context-all('module'), 'outer' 'inner');

    $_true-context.buffer = ();
  }
}

// Inspecting context
+test-module('true-context & true-context-all [functions]') {
  +test('Returns the innermost module context') {
    $_true-context.buffer = ();

    _true-context-mixin('module', 'outer');
    _true-context-mixin('module', 'inner');

    assert-equal(_true-context('module'), 'inner');

    $_true-context.buffer = ();
  }

  +test('Returns current test context') {
    $_true-context.buffer = ();

    _true-context-mixin('test', 'Returns current test context');

    assert-equal(
      _true-context('test'),
      'Returns current test context'
    );

    $_true-context.buffer = ();
  }

  +test('_true-context-all [function]') {
    $_true-context.buffer = ();

    _true-context-mixin('module', 'outer');
    _true-context-mixin('module', 'inner');

    assert-equal(
      _true-context-all('module'),
      'outer' 'inner',
      'Returns the current stack of module names'
    );

    $_true-context.buffer = ();
  }
}

// // valid output context
+test-module('true-validate-output-context [function]') {
  $valid = 'assert' 'expect' 'output' 'contains' 'contains-string';

  +test('unknown context name') {
    assert-equal(
      _true-validate-output-context('wtf'),
      "ERROR [output-context]: wtf is not a valid context for output tests: " + $valid
    )
  }

  +test('duplicate assert') {
    $_true-output-context.value = 'assert' 'output'

    assert-equal(
      _true-validate-output-context('assert'),
      'ERROR [output-context]: The `assert()` mixin can not contain another `assert()`'
    );

    $_true-output-context.value = ()
  }

  +test('duplicate output/expect') {
    $_true-output-context.value = 'assert' 'output';

    assert-equal(
      _true-validate-output-context('output'),
      'ERROR [output-context]: The `output()` mixin must only be used once per `assert()`'
    );

    $_true-output-context.value = ()
  }

  +test('mixed output assertion modes') {
    $_true-output-context.value = 'assert' 'output' 'contains';

    assert-equal(
      _true-validate-output-context('contains-string'),
      'ERROR [output-context]: Cannot mix output assertion modes in one `assert()`: found `contains-string()` after `contains()`. Split them into separate `assert()` blocks.'
    );

    $_true-output-context.value = 'assert' 'output' 'contains-string';

    assert-equal(
      _true-validate-output-context('contains'),
      'ERROR [output-context]: Cannot mix output assertion modes in one `assert()`: found `contains()` after `contains-string()`. Split them into separate `assert()` blocks.'
    );

    $_true-output-context.value = ()
  }

  +test('allows repeated contains') {
    $_true-output-context.value = 'assert' 'output' 'contains';

    assert-equal(
      _true-validate-output-context('contains'),
      'assert' 'output' 'contains' 'contains'
    );

    $_true-output-context.value = ();
  }

  +test('allows repeated contains-string') {
    $_true-output-context.value = 'assert' 'output' 'contains-string';

    assert-equal(
      _true-validate-output-context('contains-string'),
      'assert' 'output' 'contains-string' 'contains-string'
    );

    $_true-output-context.value = ();
  }

  +test('valid complete context') {
    $_true-output-context.value = 'expect' 'output' 'assert';

    assert-equal(_true-validate-output-context(null), ());

    $_true-output-context.value = ();
  }

  +test('missing assert') {
    $_true-output-context.value = 'output' 'expect';

    assert-equal(
      _true-validate-output-context(null),
      'ERROR [output-context]: The `assert()` wrapper is required'
    );

    $_true-output-context.value = ();
  }

  +test('missing output') {
    $_true-output-context.value = 'assert' 'expect';

    assert-equal(
      _true-validate-output-context(null),
      'ERROR [output-context]: Each `assert()` must contain one `output()`, and one `expect()`, `contains()`, or `contains-string()`'
    );

    $_true-output-context.value = ();
  }

  +test('missing comparison') {
    $_true-output-context.value = 'assert' 'output';

    assert-equal(
      _true-validate-output-context(null),
      'ERROR [output-context]: Each `assert()` must contain one `output()`, and one `expect()`, `contains()`, or `contains-string()`'
    );

    $_true-output-context.value = ();
  }
}

// Output context
+test-module('true-output-context [mixin]') {
  $empty-list = ();

  +test('Appends new context') {
    $before = $_true-output-context.value;
    assert-equal($before, $empty-list, 'Check initial value');

    _true-output-context('assert');
    $assert = $_true-output-context.value;
    assert-equal($assert, join((), 'assert'));

    _true-output-context('expect');
    $expect = $_true-output-context.value;
    assert-equal($expect, ('assert' 'expect'));

    _true-output-context('output');
    $output = $_true-output-context.value
    assert-equal($output, ('assert' 'expect' 'output'));
  }

  +test('Resets context') {
    _true-output-context(null);
    $reset = $_true-output-context.value
    assert-equal($reset, $empty-list, 'inspecting values', true);
  }
}
