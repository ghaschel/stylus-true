+test-module('True Error [function]') {
  +test('Allow errors to return without blocking compilation') {
    assert-equal(
      _true-error('This is a test error message', '_true-error test', true),
      'ERROR [_true-error test]: This is a test error message'
    );
  }

  +test('Public true-error returns catchable errors') {
    assert-equal(
      true-error('This is a test error message', 'true-error test', true),
      'ERROR [true-error test]: This is a test error message'
    );
  }

  +test('Public true-error uses catch-errors setting') {
    $catch-errors.value = true;

    assert-equal(
      true-error('This is a test error message', 'catch setting'),
      'ERROR [catch setting]: This is a test error message'
    );

    $catch-errors.value = false;
  }
}

+test-module('True Error [mixin]') {
  +test('Allow errors to output without blocking compilation') {
    assert() {
      +output() {
        _true-error-mixin(
          'This is a test error message',
          '_true-error test',
        );
      }
      expect() {
        _true-message('ERROR [_true-error test]:', 'comments');
        _true-message('This is a test error message', 'comments', 2);
      }
    }
  }

  +test('Public true-error outputs caught comments') {
    assert() {
      +output() {
        true-error(
          'This is a test error message',
          'true-error test',
          true
        );
      }
      expect() {
        _true-message('ERROR [true-error test]:', 'comments');
        _true-message('This is a test error message', 'comments', 2);
      }
    }
  }
}

+test-module('Map Add [function]') {
  +test('Returns a map with the sum-values of two numeric maps') {
    $base = {
      one: 1,
      two: 1,
      three: 1,
    };
    $add = {
      one: 1,
      two: 2,
      three: -1,
    };

    $expect = {
      one: 2,
      two: 3,
      three: 0,
    };
    assert-equal(_true-map-increment($base, $add), $expect);
  }
}

+test-module('Join Multiple [function]') {
  $one = 'one', 'two', 'three';
  $two = 'four' 'five' 'six';
  $three = 'seven', 'eight', 'nine';
  $joined =  'one', 'two', 'three', 'four', 'five', 'six', 'seven', 'eight', 'nine';
  $changed-separators = one two three four five six seven eight nine;

  +test('Combines multiple lists') {
    assert-equal(_true-join-multiple($one, $two, $three), $joined);
  }

  +test('Sets new list-separator') {
    assert-equal(
      _true-join-multiple($one, $two, $three, ' '),
      $changed-separators
    );
  }
}
