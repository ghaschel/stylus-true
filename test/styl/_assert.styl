// Test Assertions
// ===============

use('test/styl/plugins/use-plugin.js', { value: 37 });
defined-variable = 12px;

// Is Truthy
+test-module('Is Truthy') {
  +test('True is truthy') {
    assert-equal(_true-is-truthy(true), true);
  }

  +test('String is truthy') {
    assert-equal(_true-is-truthy('string'), true);
  }

  +test('List is truthy') {
    assert-equal(_true-is-truthy('one' 'two' 'three'), true);
  }

  +test('False is not truthy') {
    assert-equal(_true-is-truthy(false), false);
  }

  +test('Null is not truthy') {
    assert-equal(_true-is-truthy(null), false);
  }

  +test('Empty string is not truthy') {
    assert-equal(_true-is-truthy(''), false);
  }

  +test('Empty list is not truthy') {
    $list = ();

    assert-equal(_true-is-truthy($list), false);
  }
}

// Assert True
+test-module('Assert True') {
  +test('Truthiness') {
    assert-true('this string', 'Non-false properties return true.');
  }

  +test('Supports is-truthy alias') {
    is-truthy(5);
  }
}

// Assert False
+test-module('Assert False') {
  +test('Falsiness') {
    assert-false(not 'anything', 'Negated properties return false.');
  }

  +test('null') {
    assert-false(null, 'Null properties return false.');
  }

  +test('Empty string') {
    assert-false('', 'Empty string return false.');
  }

  +test('empty list') {
    $empty = ();

    assert-false($empty, 'Empty lists return false.');
  }

  +test('Supports is-falsy alias') {
    is-falsy(());
  }
}

// Assert Equal
+test-module('Assert Equal') {
  +test('Equality') {
    assert-equal(2 - 1, 1, '2 - 1 should equal 1.');
  }

  +test('Empty description') {
    assert-equal(1, 1);
  }

  +test('Adding floats') {
    assert-equal(round(0.2 + 0.1, 1), 0.3, null, true);
  }

  +test('Rounded numbers with $inspect') {
    assert-equal(round(1 / 3, 6), 0.333333, null, true);
  }

  +test('Rounded colors with $inspect') {
    $origin = #246;
    $expected = #306090;

    assert-equal(lighten($origin, 15%), $expected, null, true);
  }

  +test('Mismatched types with $inspect') {
    assert-unequal(unquote('1rem'), 1rem, null);
    assert-equal(unquote('1rem'), 1rem, null, true);
  }

  +test('Supports is-equal alias') {
    is-equal(5, 10 / 2);
  }

  +test('Supports is-equal alias with $inspect') {
    is-equal(unquote('1rem'), 1rem, null, true);
  }
}


//Assert UnEqual
+test-module('Assert UnEqual') {
  +test('Inequality') {
    assert-unequal(3 - 1, 3, '3 - 1 is not equal to 3.');
  }

  +test('Mismatched types') {
    assert-unequal(unquote('1rem'), 1rem);
  }

  +test('Mismatched units with $inspect') {
    assert-equal(1, 1rem, 'normally equal');
    assert-unequal(1, 1rem, null, true);
  }

  +test('Supports not-equal alias') {
    not-equal(5, 10 * 2);
  }

  +test('Supports not-equal alias with $inspect') {
    not-equal(1, 1rem, null, true);
  }
}

// Assert Type
+test-module('Assert Type') {
  +test('Recognizes Stylus value types') {
    assert-type(10px, 'unit');
    assert-type('value', 'string');
    assert-type(#fff, 'rgba');
    assert-type({ key: 'value' }, 'object');
    assert-type(type, 'function');
  }
}

// Assert Unit
+test-module('Assert Unit') {
  +test('Recognizes units') {
    assert-unit(10px, px);
    assert-unit(50%, '%');
    assert-unit(10, '');
  }
}

// Assert Defined
+test-module('Assert Defined') {
  +test('Finds variables, functions, and define-created symbols') {
    define('defined-from-test', 42, true);

    assert-defined('defined-variable');
    assert-defined('type');
    assert-defined('defined-from-test');
  }

  +test('Documents null lookup limitation') {
    $null-defined-variable = null;

    assert-equal(lookup('$null-defined-variable'), null);
    assert-false(lookup('$null-defined-variable') != null);
  }
}

// Assert JSON
+test-module('Assert JSON') {
  +test('Compares JSON hash fixtures') {
    assert-json(
      'test/styl/fixtures/assert-json.json',
      {
        name: 'stylus-true',
        size: 12,
        nested: {
          unit: '10px',
          flag: true
        }
      }
    );
  }

  +test('Supports custom json options without mutating caller options') {
    $options = {
      'leave-strings': false,
      hash: false
    };

    assert-json(
      'test/styl/fixtures/assert-json-values.json',
      {
        width: 10px,
        enabled: true
      },
      'parsed JSON values',
      $options
    );
    assert-equal($options.hash, false);
  }

  +test('Supports optional missing JSON fixtures') {
    assert-json(
      'test/styl/fixtures/missing.json',
      null,
      'optional missing fixture',
      { optional: true }
    );
  }
}

// Stylus JS Plugin
+test-module('Stylus use() Plugin') {
  +test('Loads JS plugins through Stylus use()') {
    assert-equal(use-plugin-value(), 37);
  }
}

// Assert [output]
+test-module('Assert(output)') {
  +test('CSS output math') {
    +assert('Output math compares properly') {
      +output() {
        -property1: round(0.1 + 0.2, 1);
        -property2: round(1 / 3, 5);
      }

      +expect() {
        -property1: 0.3;
        -property2: 0.33333;
      }
    }
  }

  +test('output/expect [mixins]') {
    +assert('Output and expected selector patterns match') {
      +output() {
        -property: value;

        @media (min-width: 30em) {
          -prop: val;

          /.selector {
            -prop: val;
          }
        }
      }

      +expect() {
        -property: value;
        @media (min-width: 30em) {
          -prop: val;

          /.selector {
            -prop: val;
          }
        }
      }
    }
  }

  +test-module('Assert(contains)') {
    +test('Passes if the property in "contains" exists in the "output" and has the same value') {
      +assert() {
        +output() {
          height: 10px;
          width: 20px;
        }

        +contains() {
          height: 10px;
        }
      }
    }

    +test('Passes if the property and its value in class in "contains" exists in the same class in "output"') {
      +assert() {
        +output() {
          height: 20px;
          .class {
            height: 10px;
          }
          .other-class {
            height: 10px;
          }
        }

        +contains() {
          .class {
            height: 10px;
          }
        }
      }
    }

    +test('Can be used with nested classes') {
      +assert() {
        +output() {
          height: 20px;
          .class {
            height: 10px;
            .other-class {
              height: 10px;
            }
          }
        }

        +contains() {
          .class {
            .other-class {
              height: 10px;
            }
          }
        }
      }
    }

    +test('Can be used with nested @media queries') {
      +assert() {
        +output() {
          .class {
            height: 20px;
          }
          @media (min-width: 30em) {
            @media (min-width: 40em) {
              .selector {
                height: 10px;
              }
              .selector2 {
                height: 10px;
              }
            }
            .selector3 {
              height: 10px;
            }
          }
        }

        +contains() {
          @media (min-width: 30em) {
            @media (min-width: 40em) {
              .selector2 {
                height: 10px;
              }
            }
          }
        }
      }
    }

    +test('Can be used with CSS level 4 selectors and nested at-rules') {
      +assert() {
        +output() {
          @media (min-width: 30em) {
            @container card (inline-size > 20rem) {
              .card:has(.title, .media):where(:not(.disabled)) {
                color: red;
                display: grid;
              }
            }
          }
        }

        +contains() {
          @media (min-width: 30em) {
            @container card (inline-size > 20rem) {
              .card:has(.title, .media):where(:not(.disabled)) {
                display: grid;
              }
            }
          }
        }
      }
    }

    +test('Can be used with root selector') {
      +assert() {
        +output() {
          /.selector {
            height: 10px;
          }
        }

        +contains() {
          /.selector {
            height: 10px;
          }
        }
      }
    }

    +test('Can be used for all selector types') {
      +assert() {
        +output() {
          .selector {
            -prop: val;
          }
          #id {
            -prop: value1;
          }
          div {
            -prop: value2;
            min-height: 20px;
            max-height: 30px;
          }

          input[type='text'] {
            color: rebeccapurple;
          }

          * + * {
            color: red;
            display: none;
          }

          body > h1 {
            font-weight: bold;
          }

          i::before {
            -prop: value3;
          }

          div ~ p {
            color: green;
          }

          i:not(.italic) {
            text-decoration: underline;
            --custom: val;
          }
        }

        +contains() {
          .selector {
            -prop: val;
          }

          div {
            max-height: 30px;
          }

          body > h1 {
            font-weight: bold;
          }

          * + * {
            display: none;
          }

          i:not(.italic) {
            text-decoration: underline;
          }
        }
      }
    }

    +test('Can assert multiple properties within a selector') {
      +assert() {
        +output() {
          .selector {
            width: 10px;
            min-height: 5px;
            max-height: 20px;
          }
        }

        +contains() {
          .selector {
            width: 10px;
            max-height: 20px;
          }
        }
      }
    }

    +test('Can assert multiple contains blocks') {
      +assert() {
        +output() {
          height: 10px;
          width: 20px;
          border: thin solid currentColor;
        }

        +contains() {
          height: 10px;
        }

        +contains() {
          width: 20px;
        }

        +contains() {
          border: thin solid currentColor;
        }
      }
    }
  }

  +test-module('Assert(contains-string)') {
    +test('Passes if the output contains a string') {
      +assert() {
        +output() {
          height: 10px;
          width: 20px;
        }

        contains-string('height');
      }
    }

    +test('Can assert multiple and overlapping strings') {
      +assert() {
        +output() {
          height: 10px;
          width: 20px;
          border: thin solid currentColor;
        }

        contains-string('height');
        contains-string('solid');
        contains-string('20px');
        contains-string('thin solid currentColor');
      }
    }
  }
}
